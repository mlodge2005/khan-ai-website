# Stripe (server-only — set in Vercel Environment Variables)
STRIPE_SECRET_KEY=sk_live_your_secret_key

# Allowed price IDs (comma-separated)
STRIPE_ALLOWED_PRICE_IDS=price_1TlcA3ID3oRDYINyeVbUwENv

# Public price id sent from the browser (must be in STRIPE_ALLOWED_PRICE_IDS)
NEXT_PUBLIC_STRIPE_PRICE_ID=price_1TlcA3ID3oRDYINyeVbUwENv

# Optional: canonical site URL for Stripe redirects (Vercel auto-detects VERCEL_URL if unset)
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
