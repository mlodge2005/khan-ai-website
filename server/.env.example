# Stripe (use test keys for development — sk_test_ / price from test mode product)
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Allowed price IDs (comma-separated). Frontend may only request these.
STRIPE_ALLOWED_PRICE_IDS=price_test_your_price_id

# Public site URL for Stripe success/cancel redirects (no trailing slash)
SITE_URL=https://mlodge2005.github.io/khan-ai-website

# Server
PORT=4242

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=https://mlodge2005.github.io,http://localhost:8080,http://127.0.0.1:8080
